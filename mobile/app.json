{
  "expo": {
    "name": "ClaimMate",
    "slug": "claimmate-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "scheme": "claimmate",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClaimMate needs access to your photos so you can upload accident evidence.",
          "cameraPermission": "ClaimMate needs camera access so you can capture accident evidence."
        }
      ],
      "expo-document-picker",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiBaseUrl": "https://claimmate-backend-production.up.railway.app",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "78a72370-b734-407c-9a1b-0ba66c5035b5"
      }
    },
    "android": {
      "package": "com.claimmate.android",
      "adaptiveIcon": {
        "backgroundColor": "#0f63ff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "owner": "mding386"
  }
}
