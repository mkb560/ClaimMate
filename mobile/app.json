{
  "expo": {
    "name": "ClaimMate",
    "slug": "claimmate-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "scheme": "claimmate",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "ClaimMate needs access to your photos so you can upload accident evidence.",
          "cameraPermission": "ClaimMate needs camera access so you can capture accident evidence."
        }
      ],
      "expo-document-picker"
    ],
    "extra": {
      "apiBaseUrl": "https://claimmate-backend-production.up.railway.app",
      "router": {
        "origin": false
      }
    },
    "android": {
      "package": "com.claimmate.android",
      "adaptiveIcon": {
        "backgroundColor": "#0f63ff"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    }
  }
}
