# Copy this file to .env and fill in the secrets or local overrides you need.

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
RAG_MODEL=gpt-5.4-mini
RAG_REASONING_EFFORT=xhigh
CLASSIFICATION_MODEL=gpt-5.4-mini
CLASSIFICATION_REASONING_EFFORT=xhigh
EMBEDDING_MODEL=text-embedding-3-large

# CORS / local dev server
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://kewu:claimmate560@localhost:5433/claimmate_test

# Auth (JWT) — leave AUTH_MODE=off for local demo/smoke without login.
# Generate a long random secret for JWT_SECRET_KEY when enabling auth.
AUTH_MODE=off
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# Optional object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_REGION=us-east-1
